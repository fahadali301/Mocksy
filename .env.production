# Mocksy backend - production environment template for Render

# App
DEBUG=False
ALGORITHM=HS256

# Security
SECRET_KEY=CHANGE_ME_generate_secure_random_string

# Database (Render injects DATABASE_URL automatically if using render.yaml database)
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DB_NAME

# Groq AI
GROQ_API_KEY=replace-with-your-groq-api-key
GROQ_ENABLED=True
